    "html": "<html lang=\"en\"><head>\n    <meta charset=\"utf-8\">\n    <title>Checking your browser… | Uzanga Secure Protection</title>\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n    <meta name=\"color-scheme\" content=\"light dark\">\n    <meta name=\"robots\" content=\"noindex, nofollow\">\n\n    <style>\n      :root {\n        --bg: #0b0e13;\n        --panel: #111827;\n        --fg: #e5e7eb;\n        --muted: #9ca3af;\n        --border: #1f2937;\n        --accent: #2563eb;\n        --ok: #22c55e;\n        --danger: #ef4444;\n        --logo-bg: rgba(37, 99, 235, 0.18);\n        --logo-border: rgba(96, 165, 250, 0.35);\n        --logo-filter: invert(1);\n      }\n\n      @media (prefers-color-scheme: light) {\n        :root {\n          --bg: #ffffff;\n          --panel: #f8fafc;\n          --fg: #020617;\n          --muted: #475569;\n          --border: #e5e7eb;\n          --logo-bg: rgba(37, 99, 235, 0.10);\n          --logo-border: rgba(37, 99, 235, 0.20);\n          --logo-filter: none;\n        }\n      }\n\n      * {\n        box-sizing: border-box;\n      }\n\n      html,\n      body {\n        height: 100%;\n        margin: 0;\n        background: var(--bg);\n        color: var(--fg);\n        font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Arial,\n          sans-serif;\n      }\n\n      body {\n        display: flex;\n        align-items: center;\n        justify-content: center;\n      }\n\n      .page {\n        width: 100%;\n        max-width: 780px;\n        padding: 40px 24px;\n      }\n\n      header {\n        display: flex;\n        align-items: center;\n        gap: 16px;\n        margin-bottom: 28px;\n      }\n\n      .logo {\n        width: 48px;\n        height: 48px;\n        border-radius: 12px;\n        display: grid;\n        place-items: center;\n        flex-shrink: 0;\n        background: var(--logo-bg);\n        border: 1px solid var(--logo-border);\n      }\n\n      .logo svg {\n        width: 100%;\n        display: block;\n        filter: var(--logo-filter);\n        opacity: 0.92;\n      }\n\n      .brand h1 {\n        margin: 0;\n        font-size: 1.4rem;\n        font-weight: 600;\n      }\n\n      .brand div {\n        font-size: 0.8rem;\n        color: var(--muted);\n        margin-top: 2px;\n      }\n\n      main {\n        background: var(--panel);\n        border: 1px solid var(--border);\n        border-radius: 16px;\n        padding: 30px 28px 34px;\n      }\n\n      p {\n        margin: 0 0 18px;\n        line-height: 1.6;\n        font-size: 0.95rem;\n        color: var(--muted);\n      }\n\n      .progress {\n        margin-top: 26px;\n      }\n\n      .bar {\n        height: 12px;\n        background: var(--border);\n        border-radius: 999px;\n        overflow: hidden;\n      }\n\n      .bar span {\n        display: block;\n        height: 100%;\n        width: 0%;\n        background: linear-gradient(90deg, var(--accent), #60a5fa);\n        transition: width 0.25s ease;\n      }\n\n      .status {\n        margin-top: 10px;\n        font-size: 0.85rem;\n        color: var(--muted);\n      }\n\n      .err {\n        display: none;\n        margin-top: 14px;\n        padding: 12px;\n        border: 1px solid var(--border);\n        border-radius: 10px;\n        background: rgba(239, 68, 68, 0.10);\n        color: var(--danger);\n        font-size: 0.85rem;\n        white-space: pre-wrap;\n      }\n\n      .meta {\n        margin-top: 28px;\n        padding-top: 20px;\n        border-top: 1px solid var(--border);\n        display: flex;\n        flex-wrap: wrap;\n        gap: 18px;\n        font-size: 0.75rem;\n        color: var(--muted);\n      }\n\n      .meta div {\n        white-space: nowrap;\n      }\n\n      .ok {\n        color: var(--ok);\n      }\n\n      footer {\n        margin-top: 26px;\n        font-size: 0.75rem;\n        color: var(--muted);\n        display: flex;\n        flex-wrap: wrap;\n        justify-content: space-between;\n        gap: 16px;\n      }\n\n      a {\n        color: var(--accent);\n        text-decoration: none;\n      }\n\n      a:hover {\n        text-decoration: underline;\n      }\n\n      noscript {\n        display: block;\n        margin-top: 18px;\n        padding: 12px;\n        border: 1px solid var(--border);\n        border-radius: 10px;\n        background: rgba(37, 99, 235, 0.08);\n        font-size: 0.85rem;\n      }\n\n      .hidden {\n        display: none !important;\n      }\n\n      .alt-method {\n        display: inline-flex;\n        align-items: center;\n        gap: 8px;\n      }\n\n      @media (prefers-reduced-motion: reduce) {\n        .bar span {\n          transition: none;\n        }\n      }\n    </style>\n  </head>\n  <body>\n    <div class=\"page\" id=\"pow-root\" role=\"main\" aria-live=\"polite\" data-redir=\"https://clothingctrl.com/\" data-pow-max-ms=\"30000\" data-min-interstitial-ms=\"7022\" data-hc-enabled=\"true\" data-hc-offer-early=\"false\">\n      <header>\n        <div class=\"logo\" aria-hidden=\"true\">\n          <svg version=\"1.0\" xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 410.000000 377.000000\" preserveAspectRatio=\"xMidYMid meet\"> <g transform=\"translate(0.000000,377.000000) scale(0.066667,-0.066667)\" fill=\"#000000\" stroke=\"none\"> <path d=\"M1133 5354 c-387 -60 -705 -349 -781 -711 -26 -128 -32 -1545 -7 -1862 34 -428 97 -747 198 -995 42 -104 90 -173 66 -95 -36 117 -43 2642 -7 2867 113 721 1214 729 1347 9 11 -59 16 -630 16 -1761 0 -1890 -7 -1758 122 -2026 198 -408 524 -578 1108 -576 1334 3 2463 1105 2581 2519 32 385 12 1886 -27 2002 -297 885 -1616 821 -1836 -90 -15 -63 -20 -283 -22 -922 -3 -948 -2 -946 -116 -1146 -334 -590 -1201 -583 -1492 11 l-55 115 -9 960 c-7 869 -11 967 -35 1042 -147 449 -595 730 -1051 659z m3941 -284 c181 -56 336 -198 413 -378 l41 -94 4 -908 c5 -914 -1 -1057 -51 -1304 -228 -1119 -1297 -1998 -2368 -1946 -277 13 -452 67 -611 187 -91 69 -90 69 87 30 216 -47 666 -47 885 0 1000 216 1731 1009 1836 1991 33 316 15 1859 -24 1943 -183 395 -701 386 -889 -14 l-39 -84 -9 -885 c-9 -957 -7 -929 -95 -1148 -295 -726 -1276 -1023 -1946 -589 l-84 55 -9 150 c-11 183 -19 176 90 70 246 -239 719 -331 1072 -209 290 100 525 318 666 618 93 196 97 239 97 1117 0 629 5 811 22 892 85 401 502 633 912 506z m-150 -456 c27 -11 69 -42 94 -68 l45 -48 4 -880 c3 -590 -1 -926 -12 -1019 -132 -1080 -1144 -1853 -2267 -1730 -340 37 -543 118 -564 227 -8 41 -13 74 -11 74 3 0 75 -24 162 -53 1050 -351 2205 233 2505 1268 62 215 70 348 70 1194 0 885 4 850 -100 850 -94 0 -95 -4 -96 -662 -1 -1117 -30 -1316 -243 -1674 -435 -731 -1463 -1061 -2186 -701 l-112 56 -5 93 c-5 109 -11 106 100 50 874 -441 1996 59 2236 997 52 204 61 365 61 1121 0 795 -2 771 85 854 75 71 150 87 234 51z\" class=\"\"></path> <path d=\"M1156 4867 c-144 -40 -258 -137 -321 -275 -32 -69 -32 -75 -32 -1292 0 -1367 4 -1449 104 -1855 82 -334 169 -555 150 -380 -26 243 -31 711 -19 1958 14 1502 12 1457 64 1519 88 104 219 116 317 29 93 -81 88 7 96 -1691 l8 -1567 39 -144 c77 -279 189 -486 350 -643 97 -96 100 -93 33 41 -59 118 -120 296 -155 453 -22 100 -26 302 -34 1800 -8 1586 -11 1692 -36 1759 -83 215 -345 349 -564 288z\"></path> <path d=\"M1264 4428 c-82 -13 -79 40 -79 -1383 0 -1399 2 -1445 76 -1732 40 -157 136 -374 224 -509 68 -103 138 -181 116 -129 -207 503 -208 516 -216 2243 -3 783 -9 1439 -12 1456 -8 36 -61 62 -109 54z\"></path> </g> </svg>\n        </div>\n        <div class=\"brand\">\n          <h1>Uzanga Secure Protection</h1>\n          <div>Automated request verification</div>\n        </div>\n      </header>\n\n      <main>\n        <p>\n          We are checking your browser before granting access. This automatic process helps\n          protect our platform from malicious traffic and abuse.\n        </p>\n\n        <p>\n          The verification usually completes in a few seconds. Please do not refresh or navigate\n          away from this page.\n        </p>\n\n        <div class=\"progress\" aria-label=\"Verification progress\">\n          <div class=\"bar\">\n            <span id=\"bar\" style=\"width: 25%;\"></span>\n          </div>\n          <div id=\"status\" class=\"status\">Fetching security challenge…</div>\n          <div id=\"err\" class=\"err\"></div>\n        </div>\n\n        <div class=\"meta\">\n          <div>Protection: Uzanga Edge</div>\n          <div>Check type: Client verification</div>\n          <div id=\"time\">Estimated time: ~6.0s</div>\n        </div>\n\n        <noscript>\n          JavaScript is required to complete this security check. Please enable JavaScript and\n          reload the page.\n        </noscript>\n      </main>\n\n      <footer>\n        <div>\n          <a id=\"alt-method\" class=\"alt-method hidden\" href=\"#\">\n            Try another method\n          </a>\n        </div>\n        <div>Need help? Contact the site owner.</div>\n        <div>Reference ID: <span id=\"ray\">ec85a751-d9c89c</span></div>\n      </footer>\n    </div>\n\n    <script>\n      (function () {\n        \"use strict\";\n\n        const root = document.getElementById(\"pow-root\");\n        const bar = document.getElementById(\"bar\");\n        const statusEl = document.getElementById(\"status\");\n        const timeEl = document.getElementById(\"time\");\n        const rayEl = document.getElementById(\"ray\");\n        const errEl = document.getElementById(\"err\");\n        const altEl = document.getElementById(\"alt-method\");\n\n        const REDIR = (root && root.dataset && root.dataset.redir) ? root.dataset.redir : \"/\";\n        const POW_MAX_MS = Number((root && root.dataset && root.dataset.powMaxMs) || 0) || 30000;\n        const HC_ENABLED = (root && root.dataset && root.dataset.hcEnabled) === \"true\";\n        const HC_OFFER_EARLY = (root && root.dataset && root.dataset.hcOfferEarly) === \"true\";\n\n        function readMs(key, fallbackMs) {\n          const raw = root && root.dataset ? root.dataset[key] : undefined;\n          const n = Number(raw);\n          if (!Number.isFinite(n)) return fallbackMs;\n          return Math.max(0, Math.floor(n));\n        }\n\n        // If PoW completes extremely quickly, keep the interstitial visible to avoid a \"blink\" UX.\n        const MIN_INTERSTITIAL_MS = readMs(\"minInterstitialMs\", 10000);\n        const FAST_COMPLETE_THRESHOLD_MS = 1000;\n        const PROBE_WINDOW_MS =\n          MIN_INTERSTITIAL_MS > 0 ? Math.min(FAST_COMPLETE_THRESHOLD_MS, MIN_INTERSTITIAL_MS) : 0;\n\n        let uiProgress = 0;\n\n        function showAltMethod() {\n          if (!HC_ENABLED || !altEl) return;\n          altEl.classList.remove(\"hidden\");\n        }\n\n        function setProgress(pct) {\n          if (!bar) return;\n          const p = Math.max(0, Math.min(100, pct));\n          uiProgress = p;\n          bar.style.width = p.toFixed(0) + \"%\";\n        }\n\n        function setEtaSeconds(secs) {\n          if (!timeEl) return;\n          const s = Math.max(0, secs);\n          timeEl.textContent = \"Estimated time: ~\" + s.toFixed(1) + \"s\";\n        }\n\n        function setStatus(msg) {\n          if (!statusEl) return;\n          statusEl.textContent = msg;\n        }\n\n        function showErr(msg) {\n          if (!errEl) return;\n          errEl.textContent = msg;\n          errEl.style.display = \"block\";\n        }\n\n        function clamp01(x) {\n          return Math.max(0, Math.min(1, x));\n        }\n\n        function lerp(a, b, t) {\n          return a + (b - a) * t;\n        }\n\n        function easeOutCubic(x) {\n          const t = clamp01(x);\n          return 1 - Math.pow(1 - t, 3);\n        }\n\n        function randId() {\n          return (\n            Math.random().toString(16).slice(2, 10) +\n            \"-\" +\n            Math.random().toString(16).slice(2, 8)\n          );\n        }\n\n        if (rayEl) rayEl.textContent = randId();\n\n        let mode = MIN_INTERSTITIAL_MS > 0 ? \"probe\" : \"real\"; // probe -> (real|delayed), or error\n        let redirectTo = \"/\";\n        let verified = false;\n\n        let delayedStartElapsedMs = 0;\n        let delayedStartProgress = 0;\n\n        // Stash real progress while we're in probe mode so we don't jump to 95% instantly.\n        let realProgress = 0;\n        let realStatus = \"\";\n        let realEtaSecs = null;\n\n        function realSetProgress(pct) {\n          realProgress = Math.max(realProgress, pct);\n          if (mode === \"real\") setProgress(realProgress);\n        }\n\n        function realSetStatus(msg) {\n          realStatus = msg;\n          if (mode === \"real\") setStatus(msg);\n        }\n\n        function realSetEta(secs) {\n          realEtaSecs = secs;\n          if (mode === \"real\") setEtaSeconds(secs);\n        }\n\n        function enterRealMode() {\n          if (mode === \"error\") return;\n          mode = \"real\";\n          // Never move the bar backwards when switching modes.\n          realProgress = Math.max(realProgress, uiProgress);\n          setProgress(realProgress);\n          if (realStatus) setStatus(realStatus);\n          if (realEtaSecs != null) setEtaSeconds(realEtaSecs);\n        }\n\n        function maybeFinishDelayed(elapsedMs) {\n          if (!verified) return false;\n          if (elapsedMs < MIN_INTERSTITIAL_MS) return false;\n\n          setProgress(100);\n          if (statusEl) statusEl.classList.add(\"ok\");\n          setStatus(\"Redirecting…\");\n          window.location.href = redirectTo || \"/\";\n          return true;\n        }\n\n        function enterDelayedMode() {\n          if (mode === \"error\") return;\n          mode = \"delayed\";\n          const elapsedMs = performance.now() - t0;\n          delayedStartElapsedMs = Math.max(0, elapsedMs);\n          delayedStartProgress = uiProgress;\n          // If min time already passed (e.g. very small min), redirect immediately.\n          maybeFinishDelayed(elapsedMs);\n        }\n\n        function probeProgress(elapsedMs) {\n          if (PROBE_WINDOW_MS <= 0) return 0;\n          const t = clamp01(elapsedMs / PROBE_WINDOW_MS);\n          return lerp(5, 24, easeOutCubic(t));\n        }\n\n        function delayedProgress(elapsedMs) {\n          if (MIN_INTERSTITIAL_MS <= 0) return 0;\n          const total = MIN_INTERSTITIAL_MS;\n          const remainMs = Math.max(1, total - delayedStartElapsedMs);\n          const t = clamp01((elapsedMs - delayedStartElapsedMs) / remainMs);\n          // Mostly linear to match the configured interstitial duration, with a small\n          // \"snap\" at the very end so it doesn't hit 100% early.\n          const snapT = 0.97;\n          if (t < snapT) return lerp(delayedStartProgress, 99, t / snapT);\n          return lerp(99, 100, (t - snapT) / (1 - snapT));\n        }\n\n        function timelineStatus(elapsedMs) {\n          if (MIN_INTERSTITIAL_MS <= 0) return \"Checking your browser…\";\n          const t = clamp01(elapsedMs / MIN_INTERSTITIAL_MS);\n          if (t < 0.10) return \"Initializing security challenge…\";\n          if (t < 0.28) return \"Fetching security challenge…\";\n          if (t < 0.88) return \"Checking your browser integrity…\";\n          if (t < 0.98) return \"Finalizing verification…\";\n          return \"Redirecting…\";\n        }\n\n        // Initial UI.\n        setProgress(5);\n        if (mode !== \"real\") {\n          setEtaSeconds(Math.max(1, Math.ceil(MIN_INTERSTITIAL_MS / 1000)));\n        } else {\n          setEtaSeconds(Math.max(1, Math.ceil(POW_MAX_MS / 1000)));\n        }\n\n        if (altEl) {\n          altEl.addEventListener(\"click\", (ev) => {\n            ev.preventDefault();\n            if (!HC_ENABLED) return;\n            window.location.href = \"hc?redir=\" + encodeURIComponent(REDIR || \"/\");\n          });\n        }\n\n        if (HC_ENABLED && HC_OFFER_EARLY) {\n          showAltMethod();\n        }\n\n        const t0 = performance.now();\n        let lastEtaInt = -1;\n        let lastStatus = \"\";\n\n        function tick() {\n          if (mode === \"probe\" || mode === \"delayed\") {\n            const elapsedMs = performance.now() - t0;\n\n            const p = (mode === \"probe\") ? probeProgress(elapsedMs) : delayedProgress(elapsedMs);\n            setProgress(p);\n\n            const st = timelineStatus(elapsedMs);\n            if (st !== lastStatus) {\n              setStatus(st);\n              lastStatus = st;\n            }\n\n            const remainingMs = Math.max(0, MIN_INTERSTITIAL_MS - elapsedMs);\n            const etaInt = Math.max(0, Math.ceil(remainingMs / 1000));\n            if (etaInt !== lastEtaInt) {\n              setEtaSeconds(etaInt);\n              lastEtaInt = etaInt;\n            }\n\n            if (mode === \"delayed\" && maybeFinishDelayed(elapsedMs)) return;\n          }\n\n          requestAnimationFrame(tick);\n        }\n        requestAnimationFrame(tick);\n\n        if (mode === \"probe\" && PROBE_WINDOW_MS > 0) {\n          setTimeout(() => {\n            if (mode !== \"probe\") return;\n            if (verified) enterDelayedMode();\n            else enterRealMode();\n          }, PROBE_WINDOW_MS);\n        }\n\n\t        function makeWorker() {\n\t          if (typeof Worker === \"undefined\") {\n\t            throw new Error(\"worker unsupported\");\n\t          }\n\t          // Use a dedicated worker file (not a blob URL) for better Safari/WebKit compatibility.\n\t          return new Worker(\"pow-worker.js\");\n\t        }\n\n        async function run() {\n          try {\n            realSetStatus(\"Fetching security challenge…\");\n            realSetProgress(12);\n            realSetEta(Math.max(1, Math.ceil(POW_MAX_MS / 1000)));\n\n            const res = await fetch(\"api/pow/challenge\", {\n              credentials: \"same-origin\",\n              headers: { accept: \"application/json\" },\n            });\n            if (!res.ok) {\n              const text = await res.text().catch(() => \"\");\n              throw new Error(\"challenge failed: \" + res.status + (text ? \" \" + text : \"\"));\n            }\n\t            const ch = await res.json();\n\t            if (!ch.challenge_token) throw new Error(\"missing challenge_token\");\n\t            const nonce = (typeof ch.nonce === \"string\") ? ch.nonce : \"\";\n\t            if (!nonce) throw new Error(\"missing nonce\");\n\n            realSetStatus(\"Solving security challenge…\");\n            realSetProgress(20);\n\n            const maxMs = POW_MAX_MS;\n            const w = makeWorker();\n            const result = await new Promise((resolve, reject) => {\n              w.onmessage = (ev) => {\n                const msg = ev.data || {};\n                if (msg.type === \"progress\") {\n                  const frac = msg.elapsed_ms ? Math.min(1, msg.elapsed_ms / maxMs) : 0;\n                  realSetProgress(20 + frac * 70);\n                  if (msg.elapsed_ms != null) {\n                    const remaining = Math.max(0, Math.ceil((maxMs - msg.elapsed_ms) / 1000));\n                    realSetEta(remaining);\n                  }\n                  if (msg.iters != null && msg.rate_hps != null) {\n                    console.debug(\"pow progress\", msg.iters, \"iters\", msg.rate_hps, \"/s\");\n                  }\n                  return;\n                }\n                resolve(msg);\n              };\n              w.onerror = (e) => reject(e);\n              w.postMessage({ nonce, difficulty: ch.difficulty, maxMs });\n            });\n            w.terminate();\n            if (!result.ok) {\n              const extra = result.elapsed_ms\n                ? \" after \" +\n                  result.elapsed_ms +\n                  \"ms (\" +\n                  result.iters +\n                  \" iters @ \" +\n                  result.rate_hps +\n                  \"/s)\"\n                : \"\";\n              throw new Error(\"pow failed: \" + result.reason + extra);\n            }\n\n            realSetStatus(\"Finalizing verification…\");\n            realSetProgress(95);\n\n            const vr = await fetch(\"api/pow/verify\", {\n              method: \"POST\",\n              credentials: \"same-origin\",\n              headers: { \"content-type\": \"application/json\", accept: \"application/json\" },\n              body: JSON.stringify({\n                challenge_token: ch.challenge_token,\n                suffix: result.suffix,\n                redir: REDIR,\n              }),\n            });\n            if (!vr.ok) {\n              const text = await vr.text().catch(() => \"\");\n              throw new Error(\"verify failed: \" + vr.status + (text ? \" \" + text : \"\"));\n            }\n            const out = await vr.json();\n            if (!out.ok) throw new Error(\"verify rejected\");\n\n            redirectTo = out.redirect || \"/\";\n            verified = true;\n\n            if (mode === \"real\" || MIN_INTERSTITIAL_MS <= 0) {\n              setProgress(100);\n              setStatus(\"Verification successful. Redirecting…\");\n              if (statusEl) statusEl.classList.add(\"ok\");\n              window.location.href = redirectTo;\n              return;\n            }\n\t          } catch (e) {\n\t            console.error(e);\n\t            if (HC_ENABLED) {\n\t              // If PoW fails (CPU too slow, worker blocked, JS error, etc), fall back to HC.\n\t              mode = \"error\";\n\t              setStatus(\"Switching to another verification method…\");\n\t              setProgress(Math.max(uiProgress, 24));\n\t              showAltMethod();\n\t              window.location.replace(\"hc?redir=\" + encodeURIComponent(REDIR || \"/\"));\n\t              return;\n\t            }\n\n            mode = \"error\";\n            showErr(String(e));\n            setStatus(\"Error\");\n            setProgress(0);\n            showAltMethod();\n          }\n        }\n\n        run();\n      })();\n    </script>\n  \n</body></html>",
